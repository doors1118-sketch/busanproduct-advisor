# v1.4.4 환경변수 설정 예시
# 실제 API key는 포함하지 마세요.

# ─── Feature Flag ───
PROMPT_MODE=legacy
# legacy: 기존 system_prompt.py 사용
# dynamic_v1_4_4: Core + Guardrail 동적 조립

APP_ENV=local
# local: logs/*.jsonl 파일 로깅
# prod: stdout structured logging

# ─── 모델 설정 ───
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
ROUTER_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gemini-2.5-flash

# ─── 모델 라우팅 정책 ───
# risk_based: 저위험 → Flash, 고위험 → Pro (비용 절감 + 품질 유지)
# pro_only: 모든 질문에 Pro 사용
# flash_only: 모든 질문에 Flash 사용 (테스트용)
MODEL_ROUTING_MODE=risk_based

# ─── Function Calling ───
MAX_TOOL_CALL_ROUNDS=3

# ─── MCP 서버 설정 ───
MCP_ENDPOINT=https://your-mcp-server.example.com
LAW_OC=your_law_oc_here

# ─── 업체 검색 API ───
COMPANY_API_KEY=your_company_api_key_here
ODCLOUD_API_KEY=your_odcloud_api_key_here

# ─── MCP 도구별 Timeout (초) ───
MCP_CHAIN_TIMEOUT_SECONDS=12
MCP_LAW_TEXT_TIMEOUT_SECONDS=10
MCP_ADMIN_RULE_TIMEOUT_SECONDS=10
MCP_DECISION_TIMEOUT_SECONDS=5
MCP_ORDINANCE_TIMEOUT_SECONDS=8

# ─── 캐시 ───
CACHE_TTL_SECONDS=3600
